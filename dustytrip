-- Helper functions
local function isInList(list, name)
    for _, item in ipairs(list) do
        if string.lower(item) == string.lower(name) then
            return true
        end
    end
    return false
end

local function getCurrentVehicle()
    local vehicleSeat = Humanoid.SeatPart
    if vehicleSeat then
        local vehicle = vehicleSeat.Parent
        if vehicle:IsA("Model") and vehicle.PrimaryPart then
            return vehicle
        end
    end
    return nil
end

local function getNearestVehicle()
    local nearest = nil
    local nearestDist = math.huge
    local rootPos = HumanoidRootPart.Position
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.PrimaryPart then
            -- Check if it's a vehicle (has attributes or matches patterns)
            if obj:GetAttribute("Fuel") or obj:GetAttribute("Radiator") or 
               obj:GetAttribute("Engine") or obj:GetAttribute("Wheels") or
               string.match(obj.Name, "car") or string.match(obj.Name, "vehicle") then
                
                local dist = (obj.PrimaryPart.Position - rootPos).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearest = obj
                end
            end
        end
    end
    return nearest
end

local function getHumanoidFromPart(part)
    local model = part.Parent
    while model do
        local hum = model:FindFirstChildWhichIsA("Humanoid")
        if hum then
            return hum, model
        end
        model = model.Parent
    end
    return nil
end

local function setupGodMode(char)
    local hum = char:WaitForChild("Humanoid")
    hum.MaxHealth = math.huge
    hum.Health = math.huge
    
    hum.HealthChanged:Connect(function(health)
        if toggles.godMode and health < math.huge then
            hum.Health = math.huge
        end
    end)
end

local function killAllMutants()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local hum = obj:FindFirstChildWhichIsA("Humanoid")
        if hum and hum.Health > 0 then
            if isInList(itemLists.mutant, obj.Name) or 
               isInList(itemLists.mutant, obj.Parent.Name) then
                hum:TakeDamage(hum.MaxHealth + 10)
            end
        end
    end
end

local function syncNanAmmo()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") then
            -- Check if it's a weapon drop
            local magSize = obj:GetAttribute("MagSize") or 
                           (obj:FindFirstChild("GunConfig") and 
                            obj.GunConfig:GetAttribute("MagSize"))
            
            if magSize then
                -- Send NaN ammo sync
                ReplicatedStorage:FindFirstChild("GunFramework_AdjustAmount"):FireServer(
                    obj, 0/0, 0/0, 0/0
                )
            end
        end
    end
end

local function bringItems(category)
    local items = itemLists[category]
    if not items or #items == 0 then return end
    
    local foundItems = {}
    local rootPos = HumanoidRootPart.Position
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj.Parent and obj.Parent.Name ~= "Camera" then
            local objName = obj.Name
            
            -- Check if this is in our list
            for _, itemName in ipairs(items) do
                if objName == itemName or string.find(objName, "^" .. itemName) then
                    if obj:IsA("BasePart") or obj:IsA("Model") then
                        table.insert(foundItems, obj)
                    end
                    break
                end
            end
        end
    end
    
    if #foundItems == 0 then return end
    
    local radius = math.clamp(#foundItems * 2, 12, 50)
    local pi = math.pi
    
    for i, obj in ipairs(foundItems) do
        local angle = (i - 1) * 2 * pi / #foundItems
        
        if obj:IsA("BasePart") then
            obj.Anchored = false
            obj.CFrame = CFrame.new(
                rootPos + Vector3.new(0, 6, 0) + 
                Vector3.new(
                    math.cos(angle) * radius,
                    math.sin(tick() + i) * 1.5,
                    math.sin(angle) * radius
                )
            )
        elseif obj:IsA("Model") and obj.PrimaryPart then
            obj.PrimaryPart.Anchored = false
            obj:SetPrimaryPartCFrame(
                CFrame.new(rootPos + Vector3.new(0, 6, 0) + 
                Vector3.new(
                    math.cos(angle) * radius,
                    math.sin(tick() + i) * 1.5,
                    math.sin(angle) * radius
                ))
            )
        end
    end
end

local function teleportCarForward(distance)
    local vehicle = car or getNearestVehicle()
    if not vehicle or not vehicle.Parent then
        vehicle = getNearestVehicle()
        car = vehicle
    end
    
    if not HumanoidRootPart then return end
    if not vehicle then return end
    
    -- Move all vehicle parts
    for _, part in ipairs(vehicle:GetDescendants()) do
        if part:IsA("BasePart") then
            -- Don't move wheels/tires
            if not string.match(part.Name, "Wheel") and 
               not string.match(part.Name, "Tire") then
                part.Anchored = false
            end
        end
    end
    
    local direction = HumanoidRootPart.CFrame.LookVector
    
    if vehicle.PrimaryPart then
        vehicle:SetPrimaryPartCFrame(
            vehicle.PrimaryPart.CFrame + direction * distance
        )
    else
        for _, part in ipairs(vehicle:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CFrame = part.CFrame + direction * distance
            end
        end
    end
    
    -- Move any players sitting in the vehicle
    for _, part in ipairs(vehicle:GetDescendants()) do
        if part:IsA("VehicleSeat") and part.Occupant then
            local occupant = part.Occupant.Parent
            if occupant then
                local root = occupant:FindFirstChild("HumanoidRootPart")
                if root then
                    root.CFrame = root.CFrame + direction * distance
                end
            end
        end
    end
    
    -- Re-anchor body parts after a short delay
    task.delay(0.5, function()
        if vehicle and vehicle.Parent then
            for _, part in ipairs(vehicle:GetDescendants()) do
                if part:IsA("BasePart") and string.match(part.Name, "Body") then
                    part.Anchored = true
                end
            end
        end
    end)
    
    -- Move the player too
    HumanoidRootPart.CFrame = HumanoidRootPart.CFrame + direction * distance
end

local function applyGodGun()
    if currentWeapon == "" or not currentWeaponHandle then return end
    
    -- Set weapon stats to infinite
    if currentWeaponHandle:GetAttribute("MagSize") then
        currentWeaponHandle:SetAttribute("MagSize", math.huge)
        currentWeaponHandle:SetAttribute("CurrentMagSize", math.huge)
        currentWeaponHandle:SetAttribute("ReserveAmmo", math.huge)
    end
    
    -- Also try GunConfig
    local gunConfig = currentWeaponHandle:FindFirstChild("GunConfig")
    if gunConfig then
        gunConfig:SetAttribute("MagSize", math.huge)
        gunConfig:SetAttribute("CurrentMagSize", math.huge)
        gunConfig:SetAttribute("ReserveAmmo", math.huge)
    end
end

-- Main heartbeat loop
RunService.Heartbeat:Connect(function(delta)
    -- Infinite Hunger
    if toggles.infHunger then
        LocalPlayer:SetAttribute("Hunger", math.huge)
        LocalPlayer:SetAttribute("hunger", math.huge)
        if Character then
            Character:SetAttribute("Hunger", math.huge)
            Character:SetAttribute("hunger", math.huge)
            if Humanoid then
                Humanoid:SetAttribute("Hunger", math.huge)
                Humanoid:SetAttribute("hunger", math.huge)
            end
        end
    end
    
    -- Infinite Stamina
    if toggles.infStamina and Humanoid then
        if Humanoid:GetAttribute("Stamina") and Humanoid:GetAttribute("Stamina") < 1 then
            Humanoid:SetAttribute("Stamina", 1)
        end
    end
    
    -- God Mode
    if toggles.godMode and Humanoid and Humanoid.Health < math.huge then
        Humanoid.Health = math.huge
    end
    
    -- Noclip
    if toggles.noclip and Character then
        for _, part in ipairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
    
    -- Car physics
    local vehicle = getCurrentVehicle()
    if vehicle then
        local speed = vehicle.AssemblyLinearVelocity.Magnitude
        local isAccelerating = UserInputService:IsKeyDown(Enum.KeyCode.W)
        
        if toggles.carPhysicsToggle and isAccelerating then
            currentBoost = currentBoost + (settings.pushStrength - currentBoost) * delta / settings.buildUpTime
            
            if speed < settings.targetTopSpeed then
                local direction = vehicle.AssemblyLinearVelocity.Unit
                if direction ~= direction then -- NaN check
                    direction = HumanoidRootPart.CFrame.LookVector
                end
                vehicle.AssemblyLinearVelocity = vehicle.AssemblyLinearVelocity + 
                    direction * currentBoost * delta
            end
        else
            currentBoost = currentBoost + (0 - currentBoost) * delta / (settings.buildUpTime * 0.5)
        end
    else
        currentBoost = 0
    end
    
    -- Periodic updates
    local currentTime = tick()
    if currentTime - lastTick >= 2.2 then
        lastTick = currentTime
        
        if toggles.killAllToggle then
            killAllMutants()
        end
        
        if toggles.godGun then
            applyGodGun()
        end
        
        if toggles.nanAmmoSync then
            syncNanAmmo()
        end
        
        -- Update vehicle state
        car = getNearestVehicle()
        if car and car.Parent then
            if toggles.infGas and car:GetAttribute("Fuel") then
                car:SetAttribute("Fuel", math.huge)
            end
            
            if toggles.infRadiator then
                Workspace:SetAttribute("RadiatorDepleteSpeed", 0)
                if car:GetAttribute("Radiator") then
                    car:SetAttribute("Radiator", math.huge)
                end
            end
            
            if toggles.infOil and car:GetAttribute("Oil") then
                car:SetAttribute("Oil", math.huge)
            end
        end
    end
    
    -- Fog
    if toggles.noFog then
        Lighting.FogEnd = 999999
    else
        Lighting.FogEnd = originalFogEnd
    end
    
    -- Brightness
    if toggles.fullBright then
        Lighting.Brightness = 10
        Lighting.GlobalShadows = false
    else
        Lighting.Brightness = originalBrightness
        Lighting.GlobalShadows = originalGlobalShadows
    end
end)

